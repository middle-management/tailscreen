+import Darwin
+import Foundation
+import libtailscale
+
+/// PacketListener is the UDP equivalent of `Listener`. There is no accept():
+/// every datagram from every source arrives on the same fd. Demultiplex by
+/// the source address returned alongside each `recv` payload.
+///
+/// Backed by `tailscale_listen_packet`, which sets up a SOCK_DGRAM socketpair
+/// inside libtailscale and pumps datagrams between the tailnet PacketConn and
+/// the C side. Each datagram on the socketpair is framed as
+///
+///     [1 byte: addr_len N][N bytes: "ip:port"][payload]
+///
+/// so the per-packet source/destination address survives the bridge.
+public actor PacketListener {
+    private var tailscale: TailscaleHandle
+    private var listener: TailscaleListener = 0
+    private var address: String
+    private let logger: LogSink?
+
+    /// Maximum bytes one datagram on the wire can carry. A UDP datagram is
+    /// capped at 64KB; we add room for the address prefix on top. Used as
+    /// the bounded read/write buffer.
+    public static let maxDatagramBytes = 64 * 1024
+
+    /// @param tailscale A handle to a Tailscale server
+    /// @param address The address (ip:port) to listen on. Per tsnet, the
+    ///                IP must be present (e.g. "0.0.0.0:7447", not just ":7447").
+    /// @param logger An optional LogSink
+    public init(tailscale: TailscaleHandle,
+                address: String,
+                logger: LogSink? = nil) async throws {
+        self.logger = logger
+        self.tailscale = tailscale
+        self.address = address
+
+        let res = tailscale_listen_packet(tailscale, "udp", address, &listener)
+        guard res == 0 else {
+            let msg = tailscale.getErrorMessage()
+            let err = TailscaleError.fromPosixErrCode(res, msg)
+            logger?.log("PacketListener failed to bind: \(msg) (\(err.localizedDescription))")
+            throw err
+        }
+        logger?.log("PacketListener bound on udp \(address)")
+    }
+
+    deinit {
+        if listener != 0 {
+            Darwin.close(listener)
+        }
+    }
+
+    /// Closes the listener. Cannot be reopened.
+    public func close() {
+        if listener != 0 {
+            Darwin.close(listener)
+            listener = 0
+        }
+    }
+
+    /// Receive one UDP datagram. Blocks up to `timeout` milliseconds.
+    ///
+    /// @returns The payload and the source address as "ip:port".
+    /// @throws TailscaleError.readFailed on timeout or read error.
+    public func recv(timeout: Int32 = 60_000) async throws -> (data: Data, from: String) {
+        let fd = listener
+        guard fd != 0 else {
+            throw TailscaleError.listenerClosed
+        }
+
+        // Release actor isolation while poll() and read() block. The actor
+        // is a single mutually-exclusive context; a synchronous poll(1s)
+        // here would queue every concurrent send() behind us, deadlocking
+        // any tight send/recv pipeline (e.g. an RTP broadcaster sharing
+        // this listener with a control-plane recv loop).
+        let result: Result<(data: Data, from: String), TailscaleError> =
+            await withCheckedContinuation { cont in
+                DispatchQueue.global(qos: .userInitiated).async {
+                    var p = pollfd(fd: fd, events: Int16(POLLIN), revents: 0)
+                    let rc = poll(&p, 1, timeout)
+                    if rc == 0 {
+                        cont.resume(returning: .failure(.readFailed))
+                        return
+                    }
+                    if rc < 0 {
+                        cont.resume(returning: .failure(.fromPosixErrCode(errno, "Poll failed")))
+                        return
+                    }
+
+                    var buffer = [UInt8](repeating: 0, count: Self.maxDatagramBytes)
+                    let bytesRead = buffer.withUnsafeMutableBufferPointer { buf -> Int in
+                        Darwin.read(fd, buf.baseAddress, buf.count)
+                    }
+                    if bytesRead <= 0 {
+                        cont.resume(returning: .failure(.readFailed))
+                        return
+                    }
+                    let addrLen = Int(buffer[0])
+                    guard 1 + addrLen <= bytesRead else {
+                        cont.resume(returning: .failure(.readFailed))
+                        return
+                    }
+                    let addrBytes = Array(buffer[1..<(1 + addrLen)])
+                    guard let addrStr = String(bytes: addrBytes, encoding: .utf8) else {
+                        cont.resume(returning: .failure(.readFailed))
+                        return
+                    }
+                    let payload = Data(buffer[(1 + addrLen)..<bytesRead])
+                    cont.resume(returning: .success((payload, addrStr)))
+                }
+            }
+        switch result {
+        case .success(let v): return v
+        case .failure(let e): throw e
+        }
+    }
+
+    /// Send one UDP datagram to the given "ip:port" destination.
+    /// Sends are best-effort; UDP semantics apply.
+    ///
+    /// @throws TailscaleError on a closed listener or framing/write error.
+    public func send(_ data: Data, to destination: String) async throws {
+        let fd = listener
+        guard fd != 0 else {
+            throw TailscaleError.connectionClosed
+        }
+        guard let addrBytes = destination.data(using: .utf8) else {
+            throw TailscaleError.shortWrite
+        }
+        guard addrBytes.count <= 255 else {
+            // The framing length byte caps addresses at 255; anything
+            // longer would silently corrupt the next datagram.
+            throw TailscaleError.shortWrite
+        }
+
+        var buf = Data(capacity: 1 + addrBytes.count + data.count)
+        buf.append(UInt8(addrBytes.count))
+        buf.append(addrBytes)
+        buf.append(data)
+        let framed = buf
+
+        // Off-actor for the same reason as recv: Darwin.write can block
+        // when the socketpair buffer is full, and we do not want one slow
+        // write to freeze concurrent recv() callers.
+        let written: Int = await withCheckedContinuation { cont in
+            DispatchQueue.global(qos: .userInitiated).async {
+                let n = framed.withUnsafeBytes { (buf: UnsafeRawBufferPointer) -> Int in
+                    guard let base = buf.baseAddress else { return -1 }
+                    return Darwin.write(fd, base, framed.count)
+                }
+                cont.resume(returning: n)
+            }
+        }
+        // SOCK_DGRAM: a successful write delivers the whole datagram. A
+        // partial/failed write means the kernel dropped this datagram —
+        // treat it as a drop and let the application's retransmit-on-loss
+        // mechanism (PLI for RTP) recover.
+        if written != framed.count {
+            throw TailscaleError.shortWrite
+        }
+    }
+}
